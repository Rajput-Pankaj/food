{
  "name": "food-delivery",
  "private": true,
  "version": "1.0.0",
  "author": "Pankaj Kumar Rajput <pankajkumarrajput1116@gmail.com>",
  "contributors": [
    "Amit Kumar"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pankajkumarrajput1116-glitch/food.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:docker": "./scripts/dev.sh",
    "build": "node scripts/vite-build.mjs",
    "lint": "eslint .",
    "test": "npm --prefix server test",
    "verify": "npm test && node scripts/vite-build.mjs",
    "preview": "vite preview",
    "seed:validate": "node scripts/validate-menu-seed.mjs",
    "export:seeds": "node scripts/export-seeds.mjs",
    "media:sync": "mkdir -p public/assets/media/blog && cp src/assets/image*.avif public/assets/media/ 2>/dev/null; cp src/assets/image14.webp public/assets/media/ 2>/dev/null; cp public/assets/media/image{1,6,10,15,20,22,8,12}.avif public/assets/media/blog/ 2>/dev/null; test -f public/assets/media/placeholder.svg || cp public/media/placeholder.svg public/assets/media/ 2>/dev/null; echo 'Media synced to public/assets/media/'",
    "deploy": "./scripts/deploy.sh",
    "docker:up": "./scripts/deploy.sh",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "api:dev": "npm --prefix server run dev",
    "api:start": "npm --prefix server start"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.12",
    "formik": "^2.4.6",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.3",
    "tailwindcss": "^4.0.12",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "vite": "^6.2.0"
  }
}
