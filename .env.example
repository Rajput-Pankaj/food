# =============================================================================
# FoodExpress — Environment Variables
# Copy to .env for Docker Compose:  cp .env.example .env
# =============================================================================

# --- Docker / Production ---
APP_PORT=8080
POSTGRES_USER=foodexpress
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=foodexpress
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:8080

# --- Frontend (Vite) ---
# Leave empty for localStorage-only dev mode (npm run dev)
# Set to /api when using Docker or a backend proxy
VITE_API_URL=

# Local dev with API: VITE_API_URL=http://localhost:3001/api

# --- Optional ---
# DATABASE_SSL=true   # for managed Postgres (Railway, Render, etc.)
