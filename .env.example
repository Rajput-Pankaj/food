# =============================================================================
# FoodExpress — Environment Variables
# Auto-generated by:  ./scripts/deploy.sh  (recommended)
# Manual copy:        cp .env.example .env
# =============================================================================

# --- App ---
APP_PORT=8080
NODE_ENV=production

# --- Database (auto-generated strong password on first deploy) ---
POSTGRES_USER=foodexpress
POSTGRES_PASSWORD=
POSTGRES_DB=foodexpress

# --- Auth (auto-generated JWT_SECRET on first deploy) ---
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS (set automatically when DOMAIN is configured) ---
CORS_ORIGIN=http://localhost:8080

# --- Public URL (used for cookies, emails, redirects) ---
# APP_URL=http://your-server-ip:8080
# APP_URL=https://food.yourdomain.com

# --- Cookie Secure flag (auto via APP_URL https://; false for plain HTTP deploy) ---
COOKIE_SECURE=false

# --- Setup wizard can update .env (domain, CORS, Traefik) when .env is mounted in API ---
ENABLE_SETUP_ENV_WRITE=true
TRAEFIK_AVAILABLE=false

# --- Force direct port mode even if Traefik exists (true/1) ---
# FORCE_STANDALONE=false

# --- Demo users (never true in production unless explicitly enabled) ---
SEED_DEMO_USERS=false

# --- First-time setup (auto-generated on deploy; required for /setup in production) ---
SETUP_TOKEN=

# --- Auth registration (set false to disable public signup) ---
ALLOW_REGISTRATION=true

# --- Domain & Traefik SSL (auto-detected by ./scripts/deploy.sh — do not hardcode your VPS host) ---
# TRAEFIK_HOST=<auto: hostname -f on VPS, e.g. srv123456.hstgr.cloud>
# TRAEFIK_SUBDOMAIN=foodexpress
# DOMAIN=<auto: ${TRAEFIK_SUBDOMAIN}.${TRAEFIK_HOST}>
# After setup wizard: change DOMAIN to your custom domain, then run ./scripts/redeploy-domain.sh
# TRAEFIK_LEGACY_DOMAIN=<previous DOMAIN kept during migration>
# TRAEFIK_HOST_RULE=Host(`yourdomain.com`) || Host(`foodexpress.srv123456.hstgr.cloud`)
# USE_TRAEFIK=true
# TRAEFIK_NETWORK=traefik
# TRAEFIK_CERT_RESOLVER=letsencrypt

# --- Razorpay (server-side secret for payment verification) ---
# RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# --- Frontend (Vite local dev only) ---
# Leave empty for localStorage-only dev mode (npm run dev)
VITE_API_URL=

# --- Email notifications (optional SMTP) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
# SMTP_FROM=noreply@yourdomain.com
# APP_URL=https://yourdomain.com

# --- Optional ---
# DATABASE_SSL=true
# SKIP_GIT_PULL=1

# =============================================================================
# Platform deploy (Coolify, Hostinger Docker, Railway, etc.)
# Paste your git repo URL, set these required env vars, use docker-compose.yml
# Required: POSTGRES_PASSWORD, JWT_SECRET, SETUP_TOKEN (generate with: openssl rand -base64 36)
# =============================================================================
